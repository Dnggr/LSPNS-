const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
let map, allReports = [], markers = [], selectedId = null;

function switchTab(t) {
  document.getElementById('form-si').style.display = t==='si'?'block':'none';
  document.getElementById('form-su').style.display = t==='su'?'block':'none';
  document.getElementById('tab-si').classList.toggle('active', t==='si');
  document.getElementById('tab-su').classList.toggle('active', t==='su');
}

async function doSignIn() {
  const btn = document.getElementById('si-btn');
  const err = document.getElementById('si-err');
  err.style.display='none'; btn.disabled=true; btn.textContent='Signing in...';
  const {data,error} = await sb.auth.signInWithPassword({
    email: document.getElementById('si-email').value.trim(),
    password: document.getElementById('si-pass').value,
  });
  btn.disabled=false; btn.textContent='Sign In';
  if(error){err.textContent=error.message;err.style.display='block';return;}
  await checkRoleAndShow(data.user);
}

async function doSignUp() {
  const btn = document.getElementById('su-btn');
  const err = document.getElementById('su-err');
  const ok = document.getElementById('su-ok');
  err.style.display='none'; ok.style.display='none';
  btn.disabled=true; btn.textContent='Creating account...';
  const {error} = await sb.auth.signUp({
    email: document.getElementById('su-email').value.trim(),
    password: document.getElementById('su-pass').value,
    options: { data: { full_name: document.getElementById('su-name').value.trim(), role: 'resident' } }
  });
  btn.disabled=false; btn.textContent='Create Account';
  if(error){err.textContent=error.message;err.style.display='block';return;}
  ok.textContent='Account created! Check your email to confirm it, then ask your admin to approve your access.';
  ok.style.display='block';
}

async function checkRoleAndShow(user) {
  const {data} = await sb.from('users').select('role,full_name').eq('id',user.id).single();
  showApp(user, data);
}

function showPending() {
  document.getElementById('auth-screen').style.display='none';
  document.getElementById('pending-screen').style.display='flex';
}
function showApp(user,profile) {
  document.getElementById('auth-screen').style.display='none';
  document.getElementById('pending-screen').style.display='none';
  document.getElementById('app').style.display='block';
  document.getElementById('user-label').textContent=`${profile?.full_name||user.email} · ${profile?.role||''}`;
  if(!map) initMap();
  loadReports();
}
async function doLogout() { await sb.auth.signOut(); location.reload(); }

function initMap() {
  map = L.map('map').setView([14.8533,121.0460],15);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{
    attribution:'© OpenStreetMap'
  }).addTo(map);
}

async function loadReports() {
  document.getElementById('report-list').innerHTML='<div class="empty">Loading...</div>';
  const {data,error} = await sb.from('reports').select('*').order('created_at',{ascending:false});
  if(error){document.getElementById('report-list').innerHTML=`<div class="empty">Error: ${error.message}</div>`;return;}
  allReports=data||[];
  applyFilter();
}

function applyFilter() {
  const sf=document.getElementById('sf').value;
  const tf=document.getElementById('tf').value;
  let f=allReports;
  if(sf!=='all') f=f.filter(r=>r.status===sf);
  if(tf!=='all') f=f.filter(r=>r.type===tf);
  renderList(f); renderMap(f); renderCounts(allReports);
}

function renderList(reports) {
  const el=document.getElementById('report-list');
  if(!reports.length){el.innerHTML='<div class="empty">No reports found.</div>';return;}
  el.innerHTML=reports.map(r=>`
    <div class="rcard ${selectedId===r.id?'selected':''}" onclick="selectReport('${r.id}')">
      <div class="rtop"><span class="rtype">${tl(r.type)}</span><span class="badge badge-${r.status}">${sl(r.status)}</span></div>
      <div class="rdesc">${r.description||'—'}</div>
      <div class="rdate">${fd(r.created_at)}</div>
    </div>`).join('');
}

function renderMap(reports) {
  markers.forEach(m=>map.removeLayer(m)); markers=[];
  const statusColor={pending:'#f59e0b',in_progress:'#3b82f6',resolved:'#10b981'};
  const typeEmoji={street_light:'💡',road_damage:'🚧',hazard:'⚠️',announcement:'📢'};
  reports.forEach(r=>{
    const color=statusColor[r.status]||'#94a3b8';
    const emoji=typeEmoji[r.type]||'📍';
    const icon=L.divIcon({
      className:'',
      html:`<div style="background:${color};border:2px solid #fff;border-radius:50%;width:32px;height:32px;display:flex;align-items:center;justify-content:center;font-size:15px;box-shadow:0 2px 6px rgba(0,0,0,.35);cursor:pointer">${emoji}</div>`,
      iconSize:[32,32],iconAnchor:[16,16],
    });
    const m=L.marker([r.lat,r.lng],{icon}).addTo(map);
    m.bindTooltip(`<strong>${tl(r.type)}</strong><br>${sl(r.status)}`,{direction:'top',offset:[0,-16]});
    m.on('click',()=>selectReport(r.id));
    markers.push(m);
  });
}

function renderCounts(reports) {
  const p=reports.filter(r=>r.status==='pending').length;
  const ip=reports.filter(r=>r.status==='in_progress').length;
  const res=reports.filter(r=>r.status==='resolved').length;
  document.getElementById('counts').innerHTML=`
    <span><span class="cdot" style="background:#f59e0b"></span>${p} pending</span>
    <span><span class="cdot" style="background:#3b82f6"></span>${ip} in progress</span>
    <span><span class="cdot" style="background:#10b981"></span>${res} resolved</span>
    <span style="margin-left:auto;color:#94a3b8">${reports.length} total</span>`;
}

async function selectReport(id) {
  selectedId=id; applyFilter();
  const r=allReports.find(x=>x.id===id); if(!r) return;
  map.panTo([r.lat,r.lng]);
  const {data:logs}=await sb.from('status_logs').select().eq('report_id',id).order('changed_at',{ascending:false});
  const logsHtml=!(logs||[]).length
    ?'<p style="color:#94a3b8;font-size:12px">No updates yet.</p>'
    :(logs||[]).map(l=>`<div class="logitem"><strong style="color:#0f766e">${l.old_status||'submitted'} → ${l.new_status}</strong>${l.note?`<div>${l.note}</div>`:''}<div style="color:#94a3b8">${fd(l.changed_at)}</div></div>`).join('');
  document.getElementById('detail-content').innerHTML=`
    <h2 style="font-size:15px;margin-bottom:12px">${tl(r.type)}</h2>
    ${r.photo_url?`<img class="dphoto" src="${r.photo_url}" onerror="this.style.display='none'" alt="photo"/>` :''}
    <div class="dlabel">Change Status</div>
    <div>
      <button class="sbtn pending ${r.status==='pending'?'active':''}" onclick="updateStatus('${r.id}','pending')">Pending</button>
      <button class="sbtn in_progress ${r.status==='in_progress'?'active':''}" onclick="updateStatus('${r.id}','in_progress')">In Progress</button>
      <button class="sbtn resolved ${r.status==='resolved'?'active':''}" onclick="updateStatus('${r.id}','resolved')">Resolved</button>
    </div>
    <div class="dlabel">Description</div><div>${r.description||'—'}</div>
    <div class="dlabel">GPS</div>
    <div style="font-family:monospace;font-size:12px">${r.lat.toFixed(6)}, ${r.lng.toFixed(6)}</div>
    <a href="https://maps.google.com/?q=${r.lat},${r.lng}" target="_blank" style="font-size:12px;color:#0f766e">Open in Google Maps ↗</a>
    <div class="dlabel">Submitted</div><div>${fd(r.created_at)}</div>
    <div class="dlabel">Status History</div><div style="margin-top:6px">${logsHtml}</div>`;
  document.getElementById('detail-panel').classList.add('open');
}

function closeDetail() { selectedId=null; document.getElementById('detail-panel').classList.remove('open'); applyFilter(); }

async function updateStatus(reportId,newStatus) {
  const {error}=await sb.from('reports').update({status:newStatus}).eq('id',reportId);
  if(error){alert('Error: '+error.message);return;}
  const r=allReports.find(x=>x.id===reportId); if(r) r.status=newStatus;
  applyFilter(); selectReport(reportId);
}

const tl=t=>({street_light:'Street Light',road_damage:'Road Damage',hazard:'Hazard',announcement:'Announcement'}[t]||t);
const sl=s=>({pending:'Pending',in_progress:'In Progress',resolved:'Resolved'}[s]||s);
const fd=d=>d?new Date(d).toLocaleDateString()+' '+new Date(d).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}):'—';

(async()=>{
  const {data}=await sb.auth.getSession();
  if(data?.session?.user) await checkRoleAndShow(data.session.user);
})();
</script>
